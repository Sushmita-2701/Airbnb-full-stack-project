<% layout("layouts/boilerplate") %>
   <style>
     #filters {
  display: flex;
  flex-wrap: nowrap;
  overflow-x: auto;
  gap: 1.2rem;
  padding: 1rem 1.5rem;
  scrollbar-width: none;
  -webkit-overflow-scrolling: touch;
}

#filters::-webkit-scrollbar {
  display: none;
}

.filter  {
  flex: 0 0 auto;
  text-align: center;
  color: red;
  background-color: #000000;
  cursor: pointer;
  transition: all 0.3s ease;
  padding: 0.5rem 0.7rem;
  border-radius: 12px;
}

.filter-icons {
  font-size: 1.3rem;
  width: 42px;
  height: 42px;
  margin: auto;
  display: flex;
  justify-content: center;
  align-items: center;
  border-radius: 50%;

  background: rgba(255, 255, 255, 0.06);
  backdrop-filter: blur(10px);
  border: 1px solid rgba(255, 255, 255, 0.08);

  transition: 0.3s;
}


.filter p {
  font-size: 0.8rem;
  margin-top: 5px;
}

/* hover effect */
.filter:hover {
  color: #ffffff;
}

.filter:hover .filter-icons {
  transform: scale(1.1);
  background: rgba(255, 56, 92, 0.15);
  border-color: #ff385c;
  color: #ff385c;
}

/* LISTING CARD MODERN LOOK */
.listing-card {
  border: none;
  border-radius: 16px;
  overflow: hidden;
  transition: all 0.3s ease;
  box-shadow: 0 4px 20px rgba(0,0,0,0.08);
}

.listing-card:hover {
  transform: translateY(-5px);
  box-shadow: 0 10px 30px rgba(0,0,0,0.15);
}

.listing-card img {
  height: 240px;
  object-fit: cover;

}

   </style>
