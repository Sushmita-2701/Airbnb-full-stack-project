<!-- Listings -->
<div class="container-fluid listing-container ">
  <div class="row row-cols-1 row-cols-md-4 g-4">
    <% for(let listing of allListings){ %>

      <div class="col-12 col-sm-6 col-md-4 col-lg-3 col-xl-3">

  <div class="card listing-card">

    <!-- IMAGE CLICK -->
    <div onclick="window.location.href='/listings/<%= listing._id %>'">
      <img src="<%= listing.image.url %>" class="card-img-top" />
    </div>

    <div class="card-body">

      <h6><%= listing.title %></h6>

      <p>₹ <%= listing.price %> / night</p>

      <p><%= listing.location %>, <%= listing.country %></p>

      <!-- BOOK BUTTON (FIXED) -->
      <button
        type="button"
        class="btn book-btn"
        onclick="window.location.href='/bookings/<%= listing._id %>'">
        Book Hostel
      </button>

    </div>

  </div>

</div>

